        "%%writefile mi_app.py\n",
        "import streamlit as st\n",
        "import pandas as pd\n",
        "import plotly.express as px\n",
        "st.set_page_config(layout=\"wide\")\n",
        "st.title(\"data ranndom\")\n",
        "st.write(\"mejor no leas esto\")\n",
        "datos = pd.DataFrame({\n",
        "    \"cosas\": [\"basura\", \"acero pero malo\", \"rubies\", \"queso\", \"pisto\", \"rubies pero feos\"],\n",
        "    \"Capa_X\": [10, 25, 5, 30, 15, 8],\n",
        "    \"Capa_Z\": [15, 5, 20, 10, 25, 2],\n",
        "    \"Profundidad_Y\": [50, 35, 15, -10, -30, -55], # El diamante estГЎ en lo mГЎs profundo\n",
        "    \"valor\": [10, 20, 300, 1000, 500, 40],     # Esto harГЎ que la burbuja sea mГЎs grande\n",
        "})\n",
        "fig = px.scatter_3d(\n",
        "    datos,\n",
        "    x='Capa_X',\n",
        "    y='Capa_Z',\n",
        "    z='Profundidad_Y',\n",
        "    color='cosas',\n",
        "    size='valor',\n",
        "    hover_name='cosas',\n",
        "     color_discrete_map={\n",
        "        \"basura\": \"#555555\",\n",
        "        \"acero pero malo\": \"#D8AF93\",\n",
        "        \"rubies\": \"#FF0000\",\n",
        "        \"queso\": \"#FCEE4B\",\n",
        "        \"pisto\": \"#00FF00\",\n",
        "        \"rubies pero feos\": \"#00FFFF\"\n",
        "    }\n",
        ")\n",
        "fig.update_layout(\n",
        "    template=\"plotly_dark\",\n",
        "    scene=dict(bgcolor=\"#111111\"),\n",
        "    margin=dict(l=0, r=0, b=0, t=0)\n",
        ")\n",
        "st.plotly_chart(fig, use_container_width=True)"
      ],
